DOMAIN=

# === Django Superuser (Admin) Setup ===
# The email address for the initial admin account (e.g., admin@example.com)
ADMIN_EMAIL=
# The password for the initial admin account
ADMIN_PASSWORD=

# === Email Configuration (SMTP) ===
# Your email address used for sending emails (e.g., your_email@gmail.com)
EMAIL_HOST_USER=
# Your email password. For Gmail, use an "App Password" (requires 2FA enabled), NOT your normal password.
EMAIL_HOST_PASSWORD=

# === Django Base Settings ===
# Django security key. Generate a secure random key for production!
SECRET_KEY=your_secret_key_here
# Debug mode (True for local development, False for production)
DEBUG=True

# === PostgreSQL Database Credentials ===
# PostgreSQL database name
DB_NAME=trainapp
# Database user name
DB_USER=trainuser
# Database password
DB_PASS=trainpass
# Database host (127.0.0.1 for local run, or "db" when using Docker Compose)
DB_HOST=127.0.0.1
# Database port
DB_PORT=5432

# === Redis & Celery Configuration ===
# URL to connect to the Redis server (e.g., redis://127.0.0.1:6379/0 for local connection)
REDIS_URL=redis://127.0.0.1:6379/0

# === Google Gemini AI ===
# API key for the AI Coach feature. Get it from: https://aistudio.google.com/app/apikey
API_GEMINI=

# === Google OAuth 2.0 (Social Login) ===
# Client ID for Google Login. Get it from Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=
# Client Secret for Google Login. Get it from Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_SECRET=

# === Cloudflare R2 Storage ===
# Set to True to enable saving media files to Cloudflare R2
USE_R2=False
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Optional: Set this if you use a custom domain or a public R2.dev domain (e.g., cdn.twojadomena.pl or pub-xxx.r2.dev)
R2_CUSTOM_DOMAIN=


