#: templates/includes/header.html:33 templates/trainers/apply.html:7
msgid "Złóż wniosek o bycie trenerem"
msgstr "Apply to be a trainer"

#: templates/includes/header.html:36
msgid "Wniosek w weryfikacji"
msgstr "Application under review"

#: templates/includes/header.html:61
msgid "Zobacz profil"
msgstr "View profile"

#: templates/includes/header.html:66
msgid "Edytuj profil"
